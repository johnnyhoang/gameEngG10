{
  "name": "gameengg10",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run dev --workspace=gameengg10-backend",
    "build:backend": "npm run build --workspace=gameengg10-backend",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "clean:build": "rimraf dist **/dist",
    "clean": "rimraf dist node_modules **/dist **/node_modules package-lock.json",
    "reinstall": "npm run clean && npm install",
    "bootstrap": "npm install && npm link --workspaces",
    "workspaces:build": "npm run build --workspaces --if-present",
    "workspaces:dev": "npm run dev --workspaces --if-present",
    "workspaces:lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.2",
    "localforage": "^1.10.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwindcss": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "workspaces": [
    "backend"
  ]
}
