# Kết nối PostgreSQL (Supabase connection string, dùng pool trực tiếp qua pg — không qua Data API)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Dùng để xác minh JWT của Supabase Auth (JWKS endpoint) — mặc định trỏ về project hiện tại nếu bỏ trống
SUPABASE_URL=https://czngbleeeiljsrpbaksg.supabase.co

# true = bật xác thực CA chain khi kết nối Postgres qua TLS (khuyến nghị, nhưng hãy test trước
# khi bật ở production — mặc định false để giữ hành vi hiện tại, không làm gãy kết nối DB).
DB_SSL_REJECT_UNAUTHORIZED=false

# Danh sách domain frontend được phép gọi API, phân tách bằng dấu phẩy.
# Bỏ trống = mở cho mọi origin (hành vi cũ, KHÔNG khuyến khích dùng ở production).
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:5173

# API key Gemini cho AI Ingest/chấm bài — có thể khai tối đa 3 key để xoay vòng khi hết quota
GEMINI_API_KEY=
GEMINI_API_KEY2=
GEMINI_API_KEY3=

PORT=3000
NODE_ENV=development
